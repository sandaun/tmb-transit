# Local overrides for your machine. Copy this file to .env.local.
# Keep only one active EXPO_PUBLIC_API_BASE_URL assignment.
# EXPO_PUBLIC_* values are bundled into the app and must never contain secrets.

EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_USE_MOCK=true
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Mock data
# Keep EXPO_PUBLIC_USE_MOCK=true. The API URL is not used, so neither the local
# API nor Cloudflare is required. This works on the simulator and an iPhone.

# Live data on the iOS simulator
# 1. Set EXPO_PUBLIC_USE_MOCK=false.
# 2. Start the API with: npm run api:dev
# 3. Keep EXPO_PUBLIC_API_BASE_URL=http://localhost:3001
# The simulator shares the Mac's network, so localhost reaches the API on the Mac.

# Live data on a physical iPhone connected to the same Wi-Fi as the Mac
# 1. Set EXPO_PUBLIC_USE_MOCK=false.
# 2. Start the API with: npm run api:dev
# 3. Replace localhost with the Mac's current LAN IP, for example:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:3001
# On an iPhone, localhost means the iPhone itself, not the Mac.

# Live data on a physical iPhone through a Cloudflare Quick Tunnel
# 1. Set EXPO_PUBLIC_USE_MOCK=false.
# 2. Start the API with: npm run api:dev
# 3. In another terminal, run:
#    cloudflared tunnel --url http://localhost:3001
# 4. Copy the HTTPS URL printed by cloudflared, for example:
# EXPO_PUBLIC_API_BASE_URL=https://example-name.trycloudflare.com
# A Quick Tunnel exposes the API on the Mac through a temporary public HTTPS URL.
# Its URL usually changes whenever cloudflared is restarted, so update this value.

# After changing an EXPO_PUBLIC_* value, reload the app. If it still uses the old
# value, restart Metro with: npx expo start --clear
