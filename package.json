{
  "name": "tmb-transit",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "npm run lint:app && npm run lint:api",
    "lint:app": "eslint app components constants hooks src --max-warnings=0",
    "lint:api": "eslint services/api/src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx 'src/**/*.test.ts'",
    "check:expo": "npx --yes expo-doctor@1.20.0",
    "validate:app-config": "tsx -e \"import './src/config/app-config.ts'\"",
    "bundle:ios": "npm run validate:app-config && expo export --platform ios --output-dir dist/ios",
    "ci:app": "npm run check:expo && npm run lint:app && npm run typecheck && npm test && npm run bundle:ios",
    "postinstall": "node ./scripts/patch-react-native-maps-codegen.js",
    "api:dev": "npm --prefix ./services/api run dev",
    "api:build": "npm --prefix ./services/api run build",
    "api:start": "npm --prefix ./services/api run start",
    "api:typecheck": "npm --prefix ./services/api run typecheck",
    "api:test": "npm --prefix ./services/api run test",
    "ci:api": "npm run lint:api && npm run api:typecheck && npm run api:test && npm run api:build"
  },
  "dependencies": {
    "@expo-google-fonts/instrument-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.80.6",
    "expo": "~54.0.35",
    "expo-blur": "~15.0.7",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "tsx": "^4.20.3",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native-maps"
      ]
    }
  }
}
